{
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "~/*": ["./app/*"],
      "@/*": ["./app/components/*"]
    }
  },
  "include": ["app/**/*", "workers/**/*", ".react-router/types/**/*", "react-router.config.ts", "vite.config.ts", "vitest.config.ts", "vitest.workspace.ts"],
  "exclude": ["node_modules", "app/**/__tests__/**", "**/*.test.ts", "**/*.test.tsx", "test/**", "stories/**"]
}
