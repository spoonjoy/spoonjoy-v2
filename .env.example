# Database
DATABASE_URL="file:./dev.db"

# Apple authentication
# Social OAuth starts remain on the registered legacy callback until the clean
# callback has been added and canaried in the Apple Developer portal.
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""
APPLE_OAUTH_CALLBACK_MODE="legacy"
APPLE_OAUTH_CLEAN_CALLBACK_REGISTERED="false"
# Native Sign in with Apple uses App ID audiences, not the social callback.
APPLE_NATIVE_CLIENT_IDS="app.spoonjoy,app.spoonjoy.mac,app.spoonjoy.Spoonjoy,app.spoonjoy.Spoonjoy.mac"

# PostHog Analytics (optional)
# Get your project API key from the PostHog project settings.
# Leave keys blank to keep telemetry disabled locally.
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST="https://us.i.posthog.com"
VITE_POSTHOG_DISABLED=""
POSTHOG_KEY=""
POSTHOG_HOST="https://us.i.posthog.com"
POSTHOG_DISABLED=""
