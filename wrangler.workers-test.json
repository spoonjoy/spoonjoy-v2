{
  "$schema": "https://json.schemastore.org/wrangler",
  "name": "spoonjoy-workers-test",
  "main": "workers/app.ts",
  "compatibility_date": "2024-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "spoonjoy-workers-test",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "vars": {
    "NODE_ENV": "test",
    "SPOONJOY_BASE_URL": "https://spoonjoy.test"
  }
}
