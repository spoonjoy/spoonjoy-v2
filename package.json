{
  "name": "spoonjoy-v2",
  "version": "1.0.0",
  "description": "Spoonjoy recipe management platform rebuilt with React Router v7 on Cloudflare",
  "type": "module",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=22 <23",
    "pnpm": "10.28.1"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "react-router dev",
    "api:playground:generate": "tsx scripts/generate-api-playground.ts",
    "build": "pnpm run api:playground:generate && react-router build",
    "preview": "wrangler pages dev",
    "deploy": "pnpm run deploy:preflight && pnpm run build && pnpm exec wrangler deploy",
    "deploy:auto": "SPOONJOY_PREFLIGHT_SKIP_REMOTE=1 pnpm run deploy:preflight && pnpm run build && pnpm exec wrangler d1 migrations apply DB --remote && pnpm run deploy:preflight && pnpm exec wrangler deploy",
    "deploy:preflight": "tsx scripts/deployment-preflight.ts",
    "production:readiness": "tsx scripts/production-readiness.ts",
    "typecheck": "pnpm run api:playground:generate && react-router typegen && tsc",
    "test": "pnpm run api:playground:generate && vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "pnpm run api:playground:generate && vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "db:seed": "pnpm exec tsx prisma/seed.ts",
    "ui:inventory": "node scripts/inventory-ui.mjs .",
    "ui:crawl": "node scripts/crawl-ui.mjs",
    "smoke:live": "node scripts/smoke-live.mjs",
    "smoke:api": "node scripts/smoke-api-live.mjs",
    "mcp:serve": "tsx scripts/spoonjoy-mcp-server.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes",
    "test:e2e": "env -u FORCE_COLOR -u NO_COLOR playwright test",
    "test:e2e:ui": "env -u FORCE_COLOR -u NO_COLOR playwright test --ui",
    "test:storybook": "test-storybook",
    "db:migrate:local:option2": "wrangler d1 execute spoonjoy --local --file=./migrations/0003_shopping_list_item_option2.sql",
    "db:migrate:local:option2:idempotent": "node ./scripts/migrate-option2-local-idempotent.mjs",
    "dev:sync": "pnpm prisma:generate && pnpm db:migrate:local:option2:idempotent && pnpm dev",
    "dev:refresh": "rm -rf node_modules/.prisma && pnpm prisma:generate"
  },
  "keywords": [
    "recipes",
    "cooking",
    "react-router",
    "cloudflare"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@block65/webcrypto-web-push": "^1.0.2",
    "@cloudflare/vite-plugin": "^1.22.1",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@posthog/react": "^1.7.0",
    "@prisma/adapter-d1": "^6.19.2",
    "@prisma/client": "6.19.2",
    "@react-router/cloudflare": "^7.13.0",
    "@react-router/dev": "^7.13.0",
    "@react-router/node": "^7.13.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "arctic": "^3.7.0",
    "bcryptjs": "^3.0.3",
    "cf-workers-og": "3.0.1",
    "clsx": "^2.1.1",
    "fraction.js": "^5.3.4",
    "framer-motion": "^12.29.2",
    "isbot": "^5.1.33",
    "lucide-react": "^0.563.0",
    "motion": "^12.29.2",
    "openai": "^6.17.0",
    "posthog-js": "^1.336.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router": "^7.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.0",
    "@cloudflare/workers-types": "^4.20260507.1",
    "@faker-js/faker": "^10.2.0",
    "@playwright/test": "^1.58.1",
    "@storybook/addon-a11y": "^10.2.1",
    "@storybook/addon-docs": "^10.2.1",
    "@storybook/addon-onboarding": "^10.2.1",
    "@storybook/addon-themes": "^10.2.1",
    "@storybook/addon-vitest": "^10.2.1",
    "@storybook/react-vite": "^10.2.1",
    "@storybook/test-runner": "^0.24.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.23",
    "chromatic": "^11.28.0",
    "happy-dom": "^20.3.7",
    "jsdom-testing-mocks": "^1.16.0",
    "pg": "^8.21.0",
    "postcss": "^8.5.6",
    "prisma": "6.19.2",
    "sharp": "^0.34.5",
    "storybook": "^10.2.1",
    "tailwindcss": "^4.1.18",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "undici": "^7.20.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.90.0"
  }
}
