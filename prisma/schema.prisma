datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

// Define your own datamodels here and run `yarn redwood prisma migrate dev`
// to create migrations for them and apply to your dev DB.

model User {
  id                  String             @id @default(cuid())
  email               String             @unique
  username            String             @unique
  // this and salt are optional because we allow OAuth only users to not have a password
  hashedPassword      String?
  salt                String?
  resetToken          String?
  resetTokenExpiresAt DateTime?
  webAuthnChallenge   String?            @unique
  photoUrl            String?
  credentials         UserCredential[]
  OAuth               OAuth[]
  recipes             Recipe[]
  shoppingList        ShoppingList?
  cookbooks           Cookbook[]
  addedToCookbooks    RecipeInCookbook[]
  apiCredentials      ApiCredential[]
  apiIdempotencyKeys  ApiIdempotencyKey[]
  agentConnections    AgentConnectionRequest[]
  oauthAuthCodes      OAuthAuthCode[]
  oauthRefreshTokens  OAuthRefreshToken[]
  spoons              RecipeSpoon[]
  imageGenLedger      ImageGenLedger[]

  pushSubscriptions      PushSubscription[]
  notificationEvents     NotificationEvent[]
  notificationPreference NotificationPreference?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model ApiCredential {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  tokenHash   String    @unique
  tokenPrefix String
  scopes      String    @default("kitchen:read kitchen:write")
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  oauthClientId String?
  oauthResource String?
  // Optional expiry. Null = non-expiring (API tokens, agent-delegated tokens).
  // OAuth-connector access tokens set this so they roll over via refresh.
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  agentConnections AgentConnectionRequest[]
  idempotencyKeys  ApiIdempotencyKey[]

  @@index([userId])
  @@index([tokenPrefix])
  @@index([oauthClientId])
  @@index([oauthResource])
}

model ApiIdempotencyKey {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId   String?
  credential     ApiCredential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  clientKey      String
  key            String
  operation      String
  requestHash    String
  responseStatus Int?
  responseBody   String?
  expiresAt      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([userId, clientKey, key])
  @@index([userId, createdAt])
  @@index([credentialId])
  @@index([expiresAt])
}

model AgentConnectionRequest {
  id             String         @id @default(cuid())
  deviceCodeHash String         @unique
  userCode       String         @unique
  agentName      String
  scopes         String         @default("kitchen:read kitchen:write")
  status         String         @default("pending")

  approvedById String?
  approvedBy   User?   @relation(fields: [approvedById], references: [id], onDelete: SetNull)

  credentialId String?
  credential   ApiCredential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)

  expiresAt  DateTime
  approvedAt DateTime?
  deniedAt   DateTime?
  claimedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([approvedById])
  @@index([credentialId])
  @@index([status, expiresAt])
}

model UserCredential {
  id         String    @id
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  publicKey  Bytes
  transports String?
  counter    BigInt
  // Optional user-given label + enrollment time, for passkey management in
  // account settings. Nullable so existing rows and the ADD COLUMN migration
  // stay trivial; new passkeys always set createdAt.
  name       String?
  createdAt  DateTime?

  @@index([userId])
}

model OAuth {
  provider         String
  // The ID of the user on the OAuth provider's system
  providerUserId   String
  // The username of the user on the OAuth provider's system. Useful for helping users identify their linked accounts
  providerUsername String
  user             User   @relation(fields: [userId], references: [id])
  userId           String

  createdAt DateTime @default(now())

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([userId])
}

// Spoonjoy acting as an OAuth 2.1 authorization server for remote MCP
// connectors (e.g. the claude.ai one-click connector). Distinct from the
// `OAuth` model above, which records Spoonjoy logging in *as a client* to
// Google/Apple. Clients self-register via Dynamic Client Registration.
model OAuthClient {
  id           String   @id @default(cuid())
  clientName   String?
  // Space-separated list of allowed redirect URIs (validated at authorize/token).
  redirectUris String
  createdAt    DateTime @default(now())
}

// Short-lived, single-use authorization codes for the PKCE auth-code grant.
model OAuthAuthCode {
  id            String    @id @default(cuid())
  codeHash      String    @unique
  clientId      String
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  redirectUri   String
  // PKCE S256 code_challenge; verified against the code_verifier at token time.
  codeChallenge String
  scope         String
  // RFC 8707 resource indicator (the MCP endpoint the token is bound to).
  resource      String?
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([userId])
}

// Long-lived refresh tokens for the connector. Rotated on every use: a refresh
// mints a new access token + new refresh token and marks the old one revoked,
// so a replayed refresh token is rejected. Stored only as a SHA-256 hash.
model OAuthRefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId  String
  scope     String
  resource  String?
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([clientId])
}

model Recipe {
  id          String             @id @default(cuid())
  title       String
  description String?
  servings    String?
  chefId      String
  chef        User               @relation(fields: [chefId], references: [id], onDelete: Cascade)
  deletedAt   DateTime?
  steps       RecipeStep[]
  cookbooks   RecipeInCookbook[]
  spoons      RecipeSpoon[]
  covers      RecipeCover[]

  sourceRecipeId String?
  sourceRecipe   Recipe? @relation("SourceRecipe", fields: [sourceRecipeId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  sourceUrl      String?

  recipeForks Recipe[] @relation("SourceRecipe")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // App actions enforce active title uniqueness because SQLite/D1 treat NULL values as distinct here.
  // This index still protects exact duplicates once deletedAt is non-null.
  @@unique([chefId, title, deletedAt])
  @@index([chefId])
  @@index([sourceRecipeId])
}

model RecipeStep {
  id          String          @id @default(cuid())
  recipeId    String
  recipe      Recipe          @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  stepNum     Int
  stepTitle   String?
  description String          
  duration    Int?
  ingredients Ingredient[]
  usingSteps  StepOutputUse[] @relation("input")
  usedBySteps StepOutputUse[] @relation("output")

  updatedAt DateTime @default(now()) @updatedAt

  @@unique([recipeId, stepNum])
  @@index([recipeId])
}

/// Allow a step to refer to the output of another step. AKA, in step 3, use the outputs from step 1 and 2
model StepOutputUse {
  id            String     @id @default(cuid())
  recipeId      String
  outputStepNum Int
  outputOfStep  RecipeStep @relation(name: "output", fields: [recipeId, outputStepNum], references: [recipeId, stepNum], onDelete: Cascade)
  inputStepNum  Int
  inputOfStep   RecipeStep @relation(name: "input", fields: [recipeId, inputStepNum], references: [recipeId, stepNum], onDelete: Cascade)

  updatedAt DateTime @default(now()) @updatedAt

  @@unique([recipeId, outputStepNum, inputStepNum])
  @@index([recipeId, outputStepNum, inputStepNum])
  @@index([recipeId, outputStepNum])
  @@index([recipeId, inputStepNum])
}

model Ingredient {
  id              String        @id @default(cuid())
  recipeId        String
  stepNum         Int
  recipeStep      RecipeStep    @relation(fields: [recipeId, stepNum], references: [recipeId, stepNum], onDelete: Cascade)
  quantity        Float
  unitId          String
  unit            Unit          @relation(fields: [unitId], references: [id])
  ingredientRefId String
  ingredientRef   IngredientRef @relation(fields: [ingredientRefId], references: [id])

  updatedAt DateTime @default(now()) @updatedAt

  @@index([recipeId, stepNum])
  @@index([recipeId])
  @@index([unitId])
  @@index([ingredientRefId])
}

model IngredientRef {
  id               String             @id @default(cuid())
  name             String             @unique
  ingredients      Ingredient[]
  shoppingListIems ShoppingListItem[]

  updatedAt DateTime @default(now()) @updatedAt
}

model Unit {
  id               String             @id @default(cuid())
  name             String             @unique
  ingredients      Ingredient[]
  shoppingListIems ShoppingListItem[]

  updatedAt DateTime @default(now()) @updatedAt
}

model Cookbook {
  id       String             @id @default(cuid())
  title    String             
  authorId String
  author   User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  recipes  RecipeInCookbook[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([authorId, title])
  @@index([authorId])
}

model RecipeInCookbook {
  id         String   @id @default(cuid())
  cookbookId String
  cookbook   Cookbook @relation(fields: [cookbookId], references: [id], onDelete: Cascade)
  recipeId   String
  recipe     Recipe   @relation(fields: [recipeId], references: [id])
  addedById  String
  addedBy    User     @relation(fields: [addedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([cookbookId, recipeId])
  @@index([cookbookId])
  @@index([recipeId])
  @@index([addedById])
  @@index([cookbookId, recipeId])
  @@index([addedById, recipeId])
}

model ShoppingList {
  id       String             @id @default(cuid())
  authorId String             @unique
  author   User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  items    ShoppingListItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([authorId])
}

model ShoppingListItem {
  id              String        @id @default(cuid())
  shoppingListId  String
  shoppingList    ShoppingList  @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  quantity        Float?
  unitId          String?
  unit            Unit?         @relation(fields: [unitId], references: [id])
  ingredientRefId String
  ingredientRef   IngredientRef @relation(fields: [ingredientRefId], references: [id])
  checked         Boolean       @default(false)
  checkedAt       DateTime?
  deletedAt       DateTime?
  sortIndex       Int           @default(0)
  categoryKey     String?
  iconKey         String?

  updatedAt DateTime @default(now()) @updatedAt

  @@unique([shoppingListId, unitId, ingredientRefId])
  @@index([shoppingListId])
  @@index([shoppingListId, deletedAt, sortIndex])
  @@index([unitId])
  @@index([ingredientRefId])
}

model RecipeSpoon {
  id        String        @id @default(cuid())
  chefId    String
  chef      User          @relation(fields: [chefId], references: [id], onDelete: Cascade)
  recipeId  String
  recipe    Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  cookedAt  DateTime      @default(now())
  photoUrl  String?
  note      String?
  nextTime  String?
  deletedAt DateTime?
  covers    RecipeCover[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([recipeId, cookedAt])
  @@index([chefId, cookedAt])
}

model RecipeCover {
  id               String       @id @default(cuid())
  recipeId         String
  recipe           Recipe       @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  imageUrl         String
  stylizedImageUrl String?
  sourceType       String
  sourceSpoonId    String?
  sourceSpoon      RecipeSpoon? @relation(fields: [sourceSpoonId], references: [id], onDelete: SetNull)
  createdAt        DateTime     @default(now())

  @@index([recipeId, createdAt])
  @@index([sourceSpoonId])
}

model ImageGenLedger {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind        String
  bucketStart DateTime
  count       Int      @default(0)

  updatedAt DateTime @default(now()) @updatedAt

  @@unique([userId, kind, bucketStart])
  @@index([userId, bucketStart])
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String   @unique
  p256dh     String
  authSecret String
  userAgent  String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now()) @updatedAt

  @@index([userId])
}

model NotificationEvent {
  id              String    @id @default(cuid())
  recipientId     String
  recipient       User      @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  kind            String
  payload         String
  createdAt       DateTime  @default(now())
  readAt          DateTime?
  pushDeliveredAt DateTime?

  @@index([recipientId, createdAt])
}

model NotificationPreference {
  userId                     String   @id
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifySpoonOnMyRecipe      Boolean  @default(true)
  notifyForkOfMyRecipe       Boolean  @default(true)
  notifyCookbookSaveOfMine   Boolean  @default(true)
  notifyFellowChefOriginCook Boolean  @default(true)
  updatedAt                  DateTime @default(now()) @updatedAt
}
